{
  "name": "calltree-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CallTree backend — single Express process, local JSON store (hackathon scaffold).",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/server.ts",
    "start": "node --env-file=.env --import tsx src/server.ts",
    "build": "tsc --noEmit false",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-ws": "^5.0.2",
    "openai": "^6.45.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-ws": "^3.0.6",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
